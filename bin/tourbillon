#!/usr/bin/env python3
"""tourbillon — keeper of the home-backup system's truth over time.

A CLI that observes, reports on, and triggers backups across the system
(saratoga ZFS replication, github+bitbucket repo mirrors, eventually
linux/mac/windows hosts). Stdlib only.

See doc/NAMING.md for the name's pedigree, PLAYBOOK.md for how the
overall system works, and doc/ADR-001-repo-mirror.md for the design
this CLI implements.

Usage:
    . ~/.config/tourbillon/env     # GITHUB_TOKEN, BITBUCKET_TOKEN, etc.
    tourbillon repos discover      # enumerate upstream; create configs

Run `tourbillon -h` for the full command tree.
"""
from __future__ import annotations

import argparse
import base64
import json
import os
import shutil
import ssl
import subprocess
import sys
import time
import tomllib
import urllib.error
import urllib.request
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Iterator

REPO_ROOT = Path(__file__).resolve().parent.parent
CONFIGS_REPOS = REPO_ROOT / "configs" / "repos"
DEFAULTS_PATH = CONFIGS_REPOS / "defaults.toml"

# Host-backups paths
CONFIGS_HOSTS = REPO_ROOT / "configs" / "hosts"
HOSTS_DEFAULTS_PATH = CONFIGS_HOSTS / "defaults.toml"
STATE_HOSTS = Path.home() / ".local" / "state" / "tourbillon" / "hosts"

# Where bare repo mirrors actually live (the ZFS dataset).
TARGET_ROOT = Path("/kodiak00/backups-00/repos")

# Mutable per-host state, NOT git-tracked.
STATE_ROOT = Path.home() / ".local" / "state" / "tourbillon" / "repos"

DEFAULTS_BODY = """\
# Tourbillon repo-mirror defaults. Per-repo files in this directory
# override these on a field-by-field basis. See doc/ADR-001-repo-mirror.md.

interval = "24h"                  # how often to sync (suffix: s|m|h|d)
target_dataset = "backups-00/repos"
on_orphan = "warn"                # warn | error  (never auto-delete)
include_collaborator = false
include_organization = false
"""

PER_REPO_TEMPLATE = """\
# Auto-created by tourbillon on first discovery.
# Per-repo settings override fields in ../../../defaults.toml.
# Add overrides below as needed; common one is a tighter interval for
# actively-developed repos:
#
#   interval = "1h"
"""


# ---------- Types ----------

@dataclass
class Repo:
    provider: str
    owner: str
    name: str
    is_private: bool
    clone_url_https: str
    default_branch: str | None = None
    pushed_at: str | None = None
    size_kb: int | None = None

    @property
    def slug(self) -> str:
        return f"{self.provider}/{self.owner}/{self.name}"


class HTTPError(Exception):
    def __init__(self, status: int, body: str, url: str):
        super().__init__(f"HTTP {status} for {url}: {body[:300]}")
        self.status = status
        self.body = body
        self.url = url


def http_get_json(url: str, headers: dict[str, str], insecure: bool = False) -> dict | list:
    """GET a JSON endpoint. `insecure=True` skips TLS cert verification — only
    use for TrueNAS's self-signed cert (matches the `curl -k` pattern in our
    shell scripts). Default verifies normally (github + bitbucket)."""
    req = urllib.request.Request(url, headers=headers)
    ctx = None
    if insecure:
        ctx = ssl.create_default_context()
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
    try:
        with urllib.request.urlopen(req, timeout=30, context=ctx) as resp:
            return json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8", errors="replace")
        raise HTTPError(e.code, body, url) from e


# ---------- Providers ----------

def github_list_owned(token: str) -> Iterator[Repo]:
    """Paginated list of owner-affiliated repos on GitHub."""
    page = 1
    while True:
        url = (
            "https://api.github.com/user/repos"
            f"?affiliation=owner&visibility=all&per_page=100&page={page}"
        )
        data = http_get_json(url, {
            "Authorization": f"Bearer {token}",
            "Accept": "application/vnd.github+json",
        })
        if not data:
            return
        for entry in data:
            yield Repo(
                provider="github",
                owner=entry["owner"]["login"],
                name=entry["name"],
                is_private=entry["private"],
                clone_url_https=entry["clone_url"],
                default_branch=entry.get("default_branch"),
                pushed_at=entry.get("pushed_at"),
                size_kb=entry.get("size"),
            )
        if len(data) < 100:
            return
        page += 1


def bitbucket_list_workspace_repos(
    workspace: str, email: str, token: str,
) -> Iterator[Repo]:
    """Paginated list of repos in a Bitbucket workspace, role=owner."""
    auth = base64.b64encode(f"{email}:{token}".encode()).decode()
    headers = {"Authorization": f"Basic {auth}"}
    url = (
        f"https://api.bitbucket.org/2.0/repositories/{workspace}"
        "?role=owner&pagelen=100"
    )
    while url:
        data = http_get_json(url, headers)
        for entry in data.get("values", []):
            clone_urls = entry.get("links", {}).get("clone", [])
            https_url = next(
                (u["href"] for u in clone_urls if u.get("name") == "https"),
                "",
            )
            yield Repo(
                provider="bitbucket",
                owner=entry["workspace"]["slug"],
                name=entry["slug"],
                is_private=entry.get("is_private", True),
                clone_url_https=https_url,
                pushed_at=entry.get("updated_on"),
                size_kb=int((entry.get("size") or 0) / 1024) or None,
            )
        url = data.get("next")


# ---------- Config files ----------

def per_repo_path(repo: Repo) -> Path:
    return CONFIGS_REPOS / repo.provider / repo.owner / f"{repo.name}.toml"


def slug_from_config_path(path: Path) -> str:
    """configs/repos/github/lynchdavis/foo.toml  ->  'github/lynchdavis/foo'"""
    rel = path.relative_to(CONFIGS_REPOS).with_suffix("")
    return "/".join(rel.parts)


def ensure_repo_config(repo: Repo) -> Path | None:
    """Create per-repo config file if missing. Returns the path if created, else None."""
    path = per_repo_path(repo)
    if path.exists():
        return None
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(PER_REPO_TEMPLATE)
    return path


def ensure_defaults() -> bool:
    """Create configs/repos/defaults.toml if missing. Returns True if created."""
    CONFIGS_REPOS.mkdir(parents=True, exist_ok=True)
    if DEFAULTS_PATH.exists():
        return False
    DEFAULTS_PATH.write_text(DEFAULTS_BODY)
    return True


# ---------- Git auto-commit ----------

def git_commit_paths(paths: list[Path], message: str) -> str | None:
    """Stage and commit just these paths. Returns short hash on success."""
    if not paths:
        return None
    rel = [str(p.relative_to(REPO_ROOT)) for p in paths]
    env = os.environ.copy()
    # Don't accidentally launch an editor from cron.
    env.setdefault("GIT_EDITOR", "true")
    subprocess.run(
        ["git", "-C", str(REPO_ROOT), "add", "--", *rel],
        check=True, env=env,
    )
    # Commit only the staged paths matching `rel`. Other unrelated staged
    # changes (if any) are left as-is.
    subprocess.run(
        ["git", "-C", str(REPO_ROOT), "commit", "-m", message, "--", *rel],
        check=True, env=env,
    )
    out = subprocess.run(
        ["git", "-C", str(REPO_ROOT), "rev-parse", "--short", "HEAD"],
        check=True, capture_output=True, text=True, env=env,
    )
    return out.stdout.strip()


# ---------- Discovery orchestration ----------

@dataclass
class DiscoveryResult:
    github_repos: list[Repo]
    github_error: str | None
    bitbucket_repos: list[Repo]
    bitbucket_error: str | None
    new_config_paths: list[Path]
    orphan_slugs: list[str]

    @property
    def all_repos(self) -> list[Repo]:
        return self.github_repos + self.bitbucket_repos

    @property
    def has_any_error(self) -> bool:
        return bool(self.github_error or self.bitbucket_error)


def discover_all() -> DiscoveryResult:
    result = DiscoveryResult(
        github_repos=[], github_error=None,
        bitbucket_repos=[], bitbucket_error=None,
        new_config_paths=[], orphan_slugs=[],
    )

    # GitHub
    gh_token = os.environ.get("GITHUB_TOKEN")
    if not gh_token:
        result.github_error = "GITHUB_TOKEN not set"
    else:
        try:
            result.github_repos = list(github_list_owned(gh_token))
        except HTTPError as e:
            result.github_error = f"HTTP {e.status}: {e.body[:200]}"
        except Exception as e:
            result.github_error = f"{type(e).__name__}: {e}"

    # Bitbucket
    bb_token = os.environ.get("BITBUCKET_TOKEN")
    bb_email = os.environ.get("ATLASSIAN_EMAIL")
    bb_workspace = os.environ.get("BITBUCKET_WORKSPACE")
    missing = [k for k, v in [
        ("BITBUCKET_TOKEN", bb_token),
        ("ATLASSIAN_EMAIL", bb_email),
        ("BITBUCKET_WORKSPACE", bb_workspace),
    ] if not v]
    if missing:
        result.bitbucket_error = f"missing env: {', '.join(missing)}"
    else:
        try:
            result.bitbucket_repos = list(
                bitbucket_list_workspace_repos(bb_workspace, bb_email, bb_token)
            )
        except HTTPError as e:
            result.bitbucket_error = f"HTTP {e.status}: {e.body[:200]}"
        except Exception as e:
            result.bitbucket_error = f"{type(e).__name__}: {e}"

    # Create per-repo config files for any new repos
    for repo in result.all_repos:
        new = ensure_repo_config(repo)
        if new:
            result.new_config_paths.append(new)

    # Detect orphans: configs that exist for repos no longer in upstream listing
    upstream_slugs = {r.slug for r in result.all_repos}
    if CONFIGS_REPOS.exists():
        for cfg in sorted(CONFIGS_REPOS.rglob("*.toml")):
            if cfg.name == "defaults.toml":
                continue
            slug = slug_from_config_path(cfg)
            # Don't mark a slug orphan if its provider had an error — we
            # might just be looking at stale data.
            provider = slug.split("/", 1)[0]
            had_error = (
                (provider == "github" and result.github_error)
                or (provider == "bitbucket" and result.bitbucket_error)
            )
            if not had_error and slug not in upstream_slugs:
                result.orphan_slugs.append(slug)

    return result


# ---------- Sync helpers ----------

def iso_now() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds").replace("+00:00", "Z")


def iso_parse(s: str) -> datetime:
    """Parse an ISO timestamp; tolerate both '...Z' and '...+00:00' suffixes."""
    return datetime.fromisoformat(s.replace("Z", "+00:00"))


def parse_interval(s: str) -> int:
    """'24h' -> 86400. Supports s/m/h/d suffixes."""
    s = s.strip().lower()
    if not s:
        raise ValueError("empty interval")
    n = int(s[:-1])
    unit = s[-1]
    return {"s": 1, "m": 60, "h": 3600, "d": 86400}[unit] * n


def format_size(b: int | float) -> str:
    b = float(b)
    for unit in ("B", "KB", "MB", "GB"):
        if b < 1024:
            return f"{b:.1f} {unit}"
        b /= 1024
    return f"{b:.1f} TB"


def format_duration(s: float) -> str:
    if s < 60:
        return f"{s:.1f}s"
    if s < 3600:
        return f"{s/60:.1f}m"
    return f"{s/3600:.2f}h"


def format_age(iso_ts: str | None, now_ts: float) -> str:
    """'2026-05-25T18:36:28Z' -> '14.2h' (relative to now)."""
    if not iso_ts:
        return "—"
    try:
        age = now_ts - iso_parse(iso_ts).timestamp()
    except ValueError:
        return "?"
    if age < 0:
        return "future?"
    if age < 60:
        return f"{int(age)}s"
    if age < 3600:
        return f"{int(age/60)}m"
    if age < 86400:
        return f"{age/3600:.1f}h"
    if age < 86400 * 30:
        return f"{age/86400:.1f}d"
    return f"{age/86400/30:.1f}mo"


def state_path(slug: str) -> Path:
    return STATE_ROOT / f"{slug}.json"


def load_state(slug: str) -> dict | None:
    p = state_path(slug)
    if not p.exists():
        return None
    try:
        return json.loads(p.read_text())
    except json.JSONDecodeError:
        return None


def save_state(slug: str, state: dict) -> None:
    p = state_path(slug)
    p.parent.mkdir(parents=True, exist_ok=True)
    p.write_text(json.dumps(state, indent=2) + "\n")


def slug_split(slug: str) -> tuple[str, str, str]:
    """'github/owner/repo' -> ('github', 'owner', 'repo')"""
    parts = slug.split("/", 2)
    if len(parts) != 3:
        raise ValueError(f"invalid slug {slug!r} (expected provider/owner/name)")
    return parts[0], parts[1], parts[2]


def public_clone_url(provider: str, owner: str, name: str) -> str:
    if provider == "github":
        return f"https://github.com/{owner}/{name}.git"
    if provider == "bitbucket":
        return f"https://bitbucket.org/{owner}/{name}.git"
    raise ValueError(f"unknown provider {provider!r}")


def git_auth_header_for(provider: str) -> str:
    """Returns the Authorization header value for git-over-HTTPS operations.

    The git HTTP backends use HTTP Basic auth, but each provider has its own
    "magic username" convention for token-based auth:

      - GitHub:    Basic x-access-token:<pat>
      - Bitbucket: Basic x-bitbucket-api-token-auth:<token>
                   (the email-as-username form works for the REST API but
                   not for git; the magic username is required here.)
    """
    if provider == "github":
        token = os.environ.get("GITHUB_TOKEN")
        if not token:
            raise RuntimeError("GITHUB_TOKEN not in environment")
        creds = base64.b64encode(f"x-access-token:{token}".encode()).decode()
        return f"Authorization: Basic {creds}"
    if provider == "bitbucket":
        token = os.environ.get("BITBUCKET_TOKEN")
        if not token:
            raise RuntimeError("BITBUCKET_TOKEN not in environment")
        creds = base64.b64encode(f"x-bitbucket-api-token-auth:{token}".encode()).decode()
        return f"Authorization: Basic {creds}"
    raise ValueError(f"unknown provider {provider!r}")


def repo_destination(provider: str, owner: str, name: str) -> Path:
    """Where the bare repo lives on disk."""
    return TARGET_ROOT / provider / owner / f"{name}.git"


def load_defaults_config() -> dict:
    if DEFAULTS_PATH.exists():
        return tomllib.loads(DEFAULTS_PATH.read_text())
    return {"interval": "24h", "on_orphan": "warn"}


def load_repo_config(slug: str, defaults: dict | None = None) -> dict:
    """defaults overridden by per-repo TOML if present."""
    if defaults is None:
        defaults = load_defaults_config()
    config = dict(defaults)
    provider, owner, name = slug_split(slug)
    per_path = CONFIGS_REPOS / provider / owner / f"{name}.toml"
    if per_path.exists():
        config.update(tomllib.loads(per_path.read_text()))
    return config


def known_slugs() -> list[str]:
    """All repo slugs we have configs for, from configs/repos/<provider>/<owner>/<name>.toml."""
    out = []
    if not CONFIGS_REPOS.exists():
        return out
    for p in sorted(CONFIGS_REPOS.rglob("*.toml")):
        if p.name == "defaults.toml":
            continue
        out.append(slug_from_config_path(p))
    return out


def dir_size_bytes(path: Path) -> int:
    total = 0
    for p in path.rglob("*"):
        if p.is_file() and not p.is_symlink():
            try:
                total += p.stat().st_size
            except OSError:
                pass
    return total


def is_due(state: dict | None, interval_s: int, now_ts: float) -> tuple[bool, str]:
    """Returns (due, reason)."""
    if state is None:
        return True, "no prior state"
    last_ok = state.get("last_success_at")
    if not last_ok:
        return True, "no successful run yet"
    last_ok_ts = iso_parse(last_ok).timestamp()
    age = now_ts - last_ok_ts
    if age > interval_s:
        return True, f"last success {format_duration(age)} ago, interval {format_duration(interval_s)}"
    return False, f"last success {format_duration(age)} ago, next in {format_duration(interval_s - age)}"


def sync_one_repo(slug: str, config: dict, dry_run: bool = False) -> dict:
    """Clone or update a single repo. Returns a result dict; never raises for
    repo-specific failures (those go into the result)."""
    provider, owner, name = slug_split(slug)
    dest = repo_destination(provider, owner, name)
    url = public_clone_url(provider, owner, name)

    try:
        header = git_auth_header_for(provider)
    except RuntimeError as e:
        return {"slug": slug, "ok": False, "action": "skip", "reason": str(e)}

    if dry_run:
        action = "clone" if not dest.exists() else "update"
        return {"slug": slug, "ok": True, "action": f"would {action}", "reason": "dry-run"}

    dest.parent.mkdir(parents=True, exist_ok=True)
    started = time.time()
    env = os.environ.copy()
    env.setdefault("GIT_TERMINAL_PROMPT", "0")  # don't hang on auth prompts

    if not dest.exists():
        # First-time clone (--mirror)
        cmd = [
            "git", "-c", f"http.extraHeader={header}",
            "clone", "--mirror", url, str(dest),
        ]
        action = "cloned"
    else:
        # Incremental update; --prune drops refs deleted upstream
        cmd = [
            "git", "-C", str(dest),
            "-c", f"http.extraHeader={header}",
            "remote", "update", "--prune",
        ]
        action = "updated"

    proc = subprocess.run(cmd, capture_output=True, text=True, env=env)
    duration = time.time() - started

    if proc.returncode != 0:
        err = (proc.stderr or proc.stdout or "<no output>").strip().splitlines()[-1]
        return {
            "slug": slug, "ok": False, "action": action,
            "reason": err, "duration_s": duration,
        }

    size = dir_size_bytes(dest) if dest.exists() else 0
    return {
        "slug": slug, "ok": True, "action": action,
        "size_bytes": size, "duration_s": duration,
    }


# ---------- Subcommands ----------

def cmd_repos_discover(args: argparse.Namespace) -> int:
    if ensure_defaults():
        rel = DEFAULTS_PATH.relative_to(REPO_ROOT)
        print(f"created {rel}")

    print("discovering...")
    result = discover_all()

    print()
    for name, repos, err in [
        ("github", result.github_repos, result.github_error),
        ("bitbucket", result.bitbucket_repos, result.bitbucket_error),
    ]:
        if err:
            print(f"  {name:9s}  ERROR: {err}", file=sys.stderr)
            continue
        pub = sum(1 for r in repos if not r.is_private)
        priv = sum(1 for r in repos if r.is_private)
        print(f"  {name:9s}  {len(repos):3d} repos  ({pub} public, {priv} private)")

    if result.new_config_paths:
        print()
        print(f"created {len(result.new_config_paths)} new per-repo config file(s):")
        for p in result.new_config_paths:
            print(f"  + {p.relative_to(REPO_ROOT)}")

        # Auto-commit (per ADR-001: local-only, never pushed)
        if args.no_commit:
            print()
            print("(--no-commit: not committing; review with `git status`)")
        else:
            n = len(result.new_config_paths)
            new_slugs = [
                slug_from_config_path(p) for p in result.new_config_paths
            ]
            slug_lines = "\n".join(f"  - {s}" for s in new_slugs)
            msg = (
                f"configs/repos: discover {n} new repo(s)\n\n"
                f"Auto-created by `tourbillon repos discover`.\n"
                f"Repos newly catalogued:\n{slug_lines}\n"
            )
            paths_to_commit = list(result.new_config_paths)
            # Also stage defaults.toml if it was newly created
            if (CONFIGS_REPOS / "defaults.toml").exists() and (
                "defaults.toml" not in [p.name for p in paths_to_commit]
            ):
                # only include defaults.toml if it's git-untracked currently
                status = subprocess.run(
                    ["git", "-C", str(REPO_ROOT), "status", "--porcelain",
                     str((DEFAULTS_PATH).relative_to(REPO_ROOT))],
                    capture_output=True, text=True, check=False,
                )
                if status.stdout.strip().startswith("??"):
                    paths_to_commit.append(DEFAULTS_PATH)
            try:
                short = git_commit_paths(paths_to_commit, msg)
                print(f"committed locally as {short} (not pushed)")
            except subprocess.CalledProcessError as e:
                print(f"  git commit failed: {e}", file=sys.stderr)
                return 1
    else:
        print()
        print("(no new configs — all upstream repos already catalogued)")

    if result.orphan_slugs:
        print()
        print(f"ORPHANED ({len(result.orphan_slugs)}) — config present, no longer in upstream:")
        for slug in result.orphan_slugs:
            print(f"  ! {slug}")
        print("(not deleted; use `tourbillon repos prune <slug>` once you're sure — n.y.i.)")

    return 1 if result.has_any_error else 0


def repo_status_row(slug: str, config: dict, state: dict | None,
                    interval_s: int, now_ts: float) -> dict:
    """Categorize a repo into one of: ok / due / FAILED / NEVER.

    'ok'     — last_success_at within interval, no error
    'due'    — last success older than interval (cron will catch it next pass)
    'FAILED' — state has last_error set
    'NEVER'  — no state file (mirror has never been attempted)
    """
    if state is None:
        return {
            "slug": slug, "state": "NEVER",
            "last_ok": None, "size": 0, "error": None,
            "interval_s": interval_s,
        }
    last_error = state.get("last_error")
    last_ok = state.get("last_success_at")
    size = state.get("last_size_bytes", 0)
    if last_error:
        return {
            "slug": slug, "state": "FAILED",
            "last_ok": last_ok, "size": size, "error": last_error,
            "interval_s": interval_s,
        }
    if not last_ok:
        # state exists but no success yet (shouldn't normally happen)
        return {
            "slug": slug, "state": "NEVER",
            "last_ok": None, "size": size, "error": None,
            "interval_s": interval_s,
        }
    age = now_ts - iso_parse(last_ok).timestamp()
    if age > interval_s:
        return {
            "slug": slug, "state": "due",
            "last_ok": last_ok, "size": size, "error": None,
            "interval_s": interval_s,
        }
    return {
        "slug": slug, "state": "ok",
        "last_ok": last_ok, "size": size, "error": None,
        "interval_s": interval_s,
    }


def print_repo_status_table(rows: list[dict], now_ts: float) -> None:
    """Print a tidy table sorted by slug. Summary line at the bottom."""
    if not rows:
        print("(no repos match)")
        return
    longest = max(len(r["slug"]) for r in rows)
    longest = max(longest, len("REPO"))
    print(f"  {'REPO':<{longest}}   {'STATE':<8}  {'LAST OK':<8}  {'SIZE':>9}  ERROR/INTERVAL")
    print(f"  {'-'*longest}   {'-'*8}  {'-'*8}  {'-'*9}  {'-'*30}")
    for r in sorted(rows, key=lambda r: r["slug"]):
        size_str = format_size(r["size"]) if r["size"] else "—"
        last = format_age(r["last_ok"], now_ts)
        state = r["state"]
        if r["error"]:
            tail = (r["error"] or "")[:60]
        else:
            tail = f"interval {format_duration(r['interval_s'])}"
        print(f"  {r['slug']:<{longest}}   {state:<8}  {last:<8}  {size_str:>9}  {tail}")

    # Summary
    counts = {"ok": 0, "due": 0, "FAILED": 0, "NEVER": 0}
    total_size = 0
    for r in rows:
        counts[r["state"]] = counts.get(r["state"], 0) + 1
        total_size += r["size"] or 0
    print()
    parts = [
        f"{counts['ok']} ok",
        f"{counts['due']} due",
        f"{counts['FAILED']} failed",
        f"{counts['NEVER']} never",
    ]
    print(f"  {' | '.join(parts)}  |  {format_size(total_size)} on disk")


# ---------- Hosts subsystem (A2) ----------

def load_hosts_defaults() -> dict:
    if not HOSTS_DEFAULTS_PATH.exists():
        return {}
    return tomllib.loads(HOSTS_DEFAULTS_PATH.read_text())


def known_host_names() -> list[str]:
    """Walk configs/hosts/ for per-host .toml files (defaults.toml excluded)."""
    if not CONFIGS_HOSTS.exists():
        return []
    return sorted(
        p.stem for p in CONFIGS_HOSTS.glob("*.toml")
        if p.name != "defaults.toml"
    )


def load_host_config(name: str, defaults: dict | None = None) -> dict:
    if defaults is None:
        defaults = load_hosts_defaults()
    cfg = dict(defaults)
    p = CONFIGS_HOSTS / f"{name}.toml"
    if p.exists():
        cfg.update(tomllib.loads(p.read_text()))
    cfg["_name"] = name
    return cfg


def host_state_path(name: str) -> Path:
    return STATE_HOSTS / f"{name}.json"


def load_host_state(name: str) -> dict | None:
    p = host_state_path(name)
    if not p.exists():
        return None
    try:
        return json.loads(p.read_text())
    except json.JSONDecodeError:
        return None


def save_host_state(name: str, state: dict) -> None:
    p = host_state_path(name)
    p.parent.mkdir(parents=True, exist_ok=True)
    p.write_text(json.dumps(state, indent=2) + "\n")


def parse_seconds_field(val) -> int:
    """Accepts '5s', '10', or 10. Returns int seconds."""
    if isinstance(val, (int, float)):
        return int(val)
    s = str(val).strip().lower()
    if s.endswith("s"):
        return int(s[:-1])
    return int(s)


def ssh_probe(host_cfg: dict) -> tuple[bool, str]:
    """`ssh -o BatchMode=yes ... true` with a short timeout.
    Returns (reachable, message). Never raises."""
    host = host_cfg.get("host", host_cfg["_name"])
    user = host_cfg.get("ssh_user", "backup")
    key = host_cfg.get("ssh_key", "")
    timeout_s = parse_seconds_field(host_cfg.get("ssh_probe_timeout", "5s"))
    cmd = [
        "ssh",
        "-o", "BatchMode=yes",
        "-o", f"ConnectTimeout={timeout_s}",
        "-o", "StrictHostKeyChecking=accept-new",
    ]
    if key:
        cmd += ["-i", key]
    cmd += [f"{user}@{host}", "true"]
    try:
        proc = subprocess.run(
            cmd, capture_output=True, text=True, timeout=timeout_s + 5
        )
    except subprocess.TimeoutExpired:
        return False, "ssh probe timed out"
    except FileNotFoundError:
        return False, "ssh binary not in PATH"
    if proc.returncode == 0:
        return True, "reachable"
    last = (proc.stderr or proc.stdout or "").strip().splitlines()
    return False, last[-1] if last else f"ssh exited {proc.returncode}"


def host_status_row(name: str, defaults: dict, now_ts: float) -> dict:
    """Categorize a host into ok / due / unreachable / FAILED / NEVER.

    Pure state-file read; no live SSH probe. (Use `hosts ping` for that.)
    """
    cfg = load_host_config(name, defaults)
    interval_s = parse_interval(str(cfg.get("schedule_when_up", "24h")))
    state = load_host_state(name)

    row = {
        "name": name,
        "host": cfg.get("host", name),
        "state": "NEVER",
        "last_success_at": None,
        "last_unreachable_at": None,
        "last_reachable_at": None,
        "last_error": None,
        "size": 0,
        "interval_s": interval_s,
    }
    if state is None:
        return row

    row["last_success_at"] = state.get("last_success_at")
    row["last_unreachable_at"] = state.get("last_unreachable_at")
    row["last_reachable_at"] = state.get("last_reachable_at")
    row["last_error"] = state.get("last_error")
    row["size"] = state.get("last_size_bytes", 0)

    # Currently unreachable if the most recent attempt was an SSH probe failure.
    last_attempt = state.get("last_attempt_at")
    if last_attempt and state.get("last_unreachable_at") == last_attempt:
        row["state"] = "unreachable"
        return row

    if state.get("last_error") and not state.get("last_success_at"):
        row["state"] = "FAILED"
        return row

    if not state.get("last_success_at"):
        row["state"] = "NEVER"
        return row

    age = now_ts - iso_parse(state["last_success_at"]).timestamp()
    if age > interval_s:
        row["state"] = "due" if not state.get("last_error") else "FAILED"
    else:
        row["state"] = "ok"
    return row


def print_hosts_table(rows: list[dict], now_ts: float) -> None:
    if not rows:
        print("  (no hosts configured — drop a config in configs/hosts/<name>.toml)")
        return
    longest = max(len(r["name"]) for r in rows)
    longest = max(longest, len("HOST"))
    print(f"  {'HOST':<{longest}}   {'STATE':<11}  {'LAST OK':<8}  {'LAST SEEN':<10}  {'SIZE':>9}  NOTE")
    print(f"  {'-'*longest}   {'-'*11}  {'-'*8}  {'-'*10}  {'-'*9}  {'-'*30}")
    for r in sorted(rows, key=lambda r: r["name"]):
        last_ok = format_age(r["last_success_at"], now_ts)
        # "last seen" = most-recent reachable attempt (whether or not sync succeeded)
        last_seen = format_age(r["last_reachable_at"], now_ts)
        size_str = format_size(r["size"]) if r["size"] else "—"
        note = ""
        if r["state"] == "unreachable":
            note = "host currently offline"
        elif r["state"] == "FAILED" and r["last_error"]:
            note = r["last_error"][:60]
        elif r["state"] == "ok":
            note = f"interval {format_duration(r['interval_s'])}"
        elif r["state"] == "NEVER":
            note = "never attempted — bootstrap + first seed pending"
        elif r["state"] == "due":
            note = f"overdue by {format_duration(now_ts - iso_parse(r['last_success_at']).timestamp() - r['interval_s'])}"
        print(f"  {r['name']:<{longest}}   {r['state']:<11}  {last_ok:<8}  {last_seen:<10}  {size_str:>9}  {note}")

    counts = {"ok": 0, "due": 0, "FAILED": 0, "NEVER": 0, "unreachable": 0}
    total_size = 0
    for r in rows:
        counts[r["state"]] = counts.get(r["state"], 0) + 1
        total_size += r["size"] or 0
    print()
    print(f"  {counts['ok']} ok | {counts['due']} due | "
          f"{counts['unreachable']} unreachable | {counts['FAILED']} failed | "
          f"{counts['NEVER']} never  |  {format_size(total_size)} on disk")


def cmd_hosts_ping(args: argparse.Namespace) -> int:
    if args.host not in known_host_names():
        print(f"unknown host: {args.host}  (no configs/hosts/{args.host}.toml)", file=sys.stderr)
        return 2
    cfg = load_host_config(args.host)
    target = f"{cfg.get('ssh_user', 'backup')}@{cfg.get('host', args.host)}"
    print(f"probing {target} ...", flush=True)
    started = time.time()
    reachable, msg = ssh_probe(cfg)
    elapsed = time.time() - started
    if reachable:
        print(f"  reachable  ({elapsed:.2f}s)")
        return 0
    print(f"  UNREACHABLE  ({elapsed:.2f}s): {msg}", file=sys.stderr)
    return 1


def cmd_hosts_status(args: argparse.Namespace) -> int:
    defaults = load_hosts_defaults()
    names = known_host_names()
    if args.name:
        names = [n for n in names if n == args.name]
    now_ts = time.time()
    rows = [host_status_row(n, defaults, now_ts) for n in names]
    print_hosts_table(rows, now_ts)
    return 0


def cmd_hosts_issues(args: argparse.Namespace) -> int:
    """Filtered view: only hosts not in 'ok' state."""
    defaults = load_hosts_defaults()
    names = known_host_names()
    now_ts = time.time()
    rows = [host_status_row(n, defaults, now_ts) for n in names]
    rows = [r for r in rows if r["state"] != "ok"]
    if not rows:
        if not args.quiet:
            print("no issues — all hosts ok within interval.")
        return 0
    print_hosts_table(rows, now_ts)
    return 1


# ---------- Top-level status sources ----------

def now_local_str() -> str:
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")


def saratoga_replication_summary() -> dict:
    """Returns {'ok': True, 'tasks': [...]} or {'ok': False, 'error': '...'}."""
    token = os.environ.get("TRUENAS_API_TOKEN")
    api_url = os.environ.get("SARATOGA_API_URL")
    if not token or not api_url:
        return {"ok": False, "error": "saratoga env not loaded (source ~/.config/saratoga/env)"}
    try:
        data = http_get_json(
            f"{api_url}/replication",
            {"Authorization": f"Bearer {token}"},
            insecure=True,   # TrueNAS uses a self-signed cert
        )
    except Exception as e:
        return {"ok": False, "error": f"{type(e).__name__}: {e}"}

    tasks = []
    for t in data:
        st = t.get("state") or {}
        last_dt = (st.get("datetime") or {}).get("$date")
        tasks.append({
            "name": t.get("name", "?"),
            "state": st.get("state", "?"),
            "last_snapshot": st.get("last_snapshot"),
            "last_ts_ms": last_dt,
            "progress": ((t.get("job") or {}).get("progress") or {}).get("description"),
        })
    return {"ok": True, "tasks": tasks}


def repos_summary_dict() -> dict:
    """One-pass walk over configs + state. Returns counts + oldest/newest sync timestamps."""
    defaults = load_defaults_config()
    slugs = known_slugs()
    now_ts = time.time()

    counts = {"ok": 0, "due": 0, "FAILED": 0, "NEVER": 0}
    by_provider = {"github": 0, "bitbucket": 0}
    total_size = 0
    oldest = (None, None)  # (slug, age_seconds)
    newest = (None, None)

    for slug in slugs:
        provider = slug.split("/", 1)[0]
        by_provider[provider] = by_provider.get(provider, 0) + 1

        config = load_repo_config(slug, defaults)
        interval_s = parse_interval(str(config.get("interval", "24h")))
        state = load_state(slug)
        row = repo_status_row(slug, config, state, interval_s, now_ts)
        counts[row["state"]] += 1
        total_size += row["size"] or 0

        if row["last_ok"]:
            age = now_ts - iso_parse(row["last_ok"]).timestamp()
            if oldest[1] is None or age > oldest[1]:
                oldest = (slug, age)
            if newest[1] is None or age < newest[1]:
                newest = (slug, age)

    return {
        "counts": counts,
        "by_provider": by_provider,
        "total_size": total_size,
        "oldest": oldest,
        "newest": newest,
        "n": len(slugs),
    }


def pool_status_dict(pool: str = "backups-00") -> dict:
    """Reads via `zpool list -Hp` + `zpool status`. Returns shaped dict, never raises."""
    out: dict = {"pool": pool}
    try:
        proc = subprocess.run(
            ["zpool", "list", "-Hp", "-o", "size,alloc,free,cap,health", pool],
            capture_output=True, text=True, check=True,
        )
        size, alloc, free, cap, health = proc.stdout.strip().split("\t")
        out["size"] = int(size)
        out["alloc"] = int(alloc)
        out["free"] = int(free)
        out["capacity_pct"] = int(cap)
        out["health"] = health
    except Exception as e:
        out["error"] = f"zpool list: {e}"
        return out

    try:
        proc = subprocess.run(
            ["zpool", "status", pool], capture_output=True, text=True, check=True,
        )
        scan_line = None
        for raw in proc.stdout.splitlines():
            line = raw.strip()
            if line.startswith("scan:"):
                scan_line = line[len("scan:"):].strip()
                continue
            parts = line.split()
            if len(parts) >= 5 and (parts[0].startswith("ata-") or parts[0].startswith("/dev/")):
                try:
                    out["read_errors"] = int(parts[2])
                    out["write_errors"] = int(parts[3])
                    out["cksum_errors"] = int(parts[4])
                except ValueError:
                    pass
        out["scan"] = scan_line or "none requested"
    except Exception as e:
        out["status_error"] = f"zpool status: {e}"

    return out


def next_scrub_dict() -> dict | None:
    """Read the next-scheduled scrub timer firing (if installed)."""
    try:
        proc = subprocess.run(
            ["systemctl", "list-timers", "--no-pager", "--no-legend", "zfs-scrub*"],
            capture_output=True, text=True, check=False,
        )
        for line in proc.stdout.splitlines():
            line = line.strip()
            if not line:
                continue
            parts = line.split()
            if len(parts) < 4:
                continue
            return {"next": " ".join(parts[:3]), "tz": parts[3], "unit": parts[-2] if len(parts) >= 2 else ""}
    except Exception:
        return None
    return None


def smart_attrs_dict(device: str = "/dev/sdb") -> dict:
    """smartctl -A + selftest; condense to key attributes. Never raises."""
    out: dict = {"device": device}
    try:
        proc = subprocess.run(
            ["sudo", "-n", "/usr/sbin/smartctl", "-A", "-i", device],
            capture_output=True, text=True, check=False,
        )
        for line in proc.stdout.splitlines():
            if line.startswith("Device Model:"):
                out["model"] = line.split(":", 1)[1].strip()
            elif line.startswith("Serial Number:"):
                out["serial"] = line.split(":", 1)[1].strip()
            elif "Reallocated_Sector_Ct" in line:
                out["reallocated"] = int(line.split()[-1])
            elif "Current_Pending_Sector" in line:
                out["pending"] = int(line.split()[-1])
            elif "Offline_Uncorrectable" in line:
                out["uncorrectable"] = int(line.split()[-1])
            elif "Power_On_Hours" in line:
                out["power_on_hours"] = int(line.split()[-1])
    except Exception as e:
        out["error"] = str(e)

    try:
        proc = subprocess.run(
            ["sudo", "-n", "/usr/sbin/smartctl", "-l", "selftest", device],
            capture_output=True, text=True, check=False,
        )
        for line in proc.stdout.splitlines():
            stripped = line.strip()
            if stripped.startswith("# 1 "):
                out["last_test"] = " ".join(stripped.split())
                break
    except Exception:
        pass

    return out


# ---------- Top-level status formatter ----------

def print_status() -> int:
    print(f"tourbillon status     {now_local_str()}")
    print()

    # --- Saratoga replication ---
    print("== Saratoga DR (TrueNAS push -> backups-00/saratoga) ==")
    print()
    sara = saratoga_replication_summary()
    if not sara["ok"]:
        print(f"  (unavailable) {sara['error']}")
    else:
        now_ms = time.time() * 1000
        for t in sara["tasks"]:
            age_str = "—"
            if t["last_ts_ms"]:
                age_s = (now_ms - t["last_ts_ms"]) / 1000
                age_str = format_duration(age_s) + " ago" if age_s > 0 else "future?"
            name_short = t["name"].split(" - ", 1)[0]
            line = f"  {name_short:<10} {t['state']:<10} {age_str:<14}"
            if t["last_snapshot"]:
                line += f"last: {t['last_snapshot']}"
            print(line)
            # Only show progress when the task is ACTIVELY running — otherwise
            # the "progress" field still holds the final state of the last run
            # ("Sending 147 of 147 ...") and reads as if it were in-flight.
            if t.get("progress") and t.get("state") == "RUNNING":
                print(f"             progress: {t['progress']}")
    print()

    # --- Repos ---
    print("== Repo mirrors (backups-00/repos) ==")
    print()
    r = repos_summary_dict()
    c = r["counts"]
    parts = [f"{c['ok']} ok", f"{c['due']} due", f"{c['FAILED']} failed", f"{c['NEVER']} never"]
    print(f"  {' | '.join(parts)}  |  "
          f"{format_size(r['total_size'])} across "
          f"{r['by_provider'].get('github', 0)} github + {r['by_provider'].get('bitbucket', 0)} bitbucket  "
          f"(n={r['n']})")
    if r["oldest"][0]:
        print(f"  oldest sync: {r['oldest'][0]}  ({format_duration(r['oldest'][1])} ago)")
    if r["newest"][0]:
        print(f"  newest sync: {r['newest'][0]}  ({format_duration(r['newest'][1])} ago)")
    print()

    # --- Pool ---
    print("== Pool health (backups-00) ==")
    print()
    p = pool_status_dict()
    if "error" in p:
        print(f"  (unavailable) {p['error']}")
    else:
        print(f"  state:    {p.get('health', '?')}")
        print(f"  capacity: {format_size(p['alloc'])} used / "
              f"{format_size(p['free'])} free  ({p['capacity_pct']}%)")
        re_ = p.get("read_errors", "?"); we_ = p.get("write_errors", "?"); ce_ = p.get("cksum_errors", "?")
        print(f"  errors:   {re_} read / {we_} write / {ce_} checksum")
        if p.get("scan"):
            print(f"  scan:     {p['scan']}")
    nxt = next_scrub_dict()
    if nxt and nxt.get("next"):
        print(f"  next scrub: {nxt['next']} {nxt.get('tz', '')}  ({nxt.get('unit', '')})")
    print()

    # --- Drive ---
    print("== Drive health (/dev/sdb) ==")
    print()
    s = smart_attrs_dict("/dev/sdb")
    if "error" in s and not any(k in s for k in ("reallocated", "pending", "power_on_hours")):
        print(f"  (unavailable) {s['error']}")
    else:
        if s.get("model"):
            tail = f"S/N {s['serial']}" if s.get("serial") else ""
            print(f"  drive:        {s['model']}  {tail}".rstrip())
        for label, key in [
            ("reallocated", "reallocated"),
            ("pending", "pending"),
            ("uncorrectable", "uncorrectable"),
            ("power-on hrs", "power_on_hours"),
        ]:
            if key in s:
                print(f"  {label + ':':<16}{s[key]}")
        if s.get("last_test"):
            print(f"  {'last test:':<16}{s['last_test']}")
    print()

    return 0


def cmd_status(args: argparse.Namespace) -> int:
    return print_status()


def cmd_repos_status(args: argparse.Namespace) -> int:
    defaults = load_defaults_config()
    slugs = known_slugs()
    if args.provider:
        slugs = [s for s in slugs if s.startswith(args.provider + "/")]
    if args.name:
        slugs = [s for s in slugs if s == args.name]

    now_ts = time.time()
    rows = []
    for slug in slugs:
        config = load_repo_config(slug, defaults)
        interval_s = parse_interval(str(config.get("interval", "24h")))
        state = load_state(slug)
        rows.append(repo_status_row(slug, config, state, interval_s, now_ts))

    print_repo_status_table(rows, now_ts)
    return 0


def cmd_repos_issues(args: argparse.Namespace) -> int:
    """Filtered view: only rows that aren't 'ok'."""
    defaults = load_defaults_config()
    slugs = known_slugs()
    if args.provider:
        slugs = [s for s in slugs if s.startswith(args.provider + "/")]

    now_ts = time.time()
    rows = []
    for slug in slugs:
        config = load_repo_config(slug, defaults)
        interval_s = parse_interval(str(config.get("interval", "24h")))
        state = load_state(slug)
        row = repo_status_row(slug, config, state, interval_s, now_ts)
        if row["state"] != "ok":
            rows.append(row)

    if not rows:
        # Cron-friendly: nothing wrong means no output.
        if not args.quiet:
            print("no issues — all repos ok within interval.")
        return 0

    print_repo_status_table(rows, now_ts)
    return 1  # non-zero exit because there ARE issues


def cmd_repos_sync(args: argparse.Namespace) -> int:
    if not TARGET_ROOT.exists():
        print(f"ERROR: target dataset not present: {TARGET_ROOT}", file=sys.stderr)
        print("  did you create backups-00/repos? See PLAYBOOK 'Adding a new replication target'", file=sys.stderr)
        return 1

    defaults = load_defaults_config()

    # Decide which slugs to consider
    if args.name:
        slugs = [args.name]
    else:
        slugs = known_slugs()
    if args.provider:
        slugs = [s for s in slugs if s.startswith(args.provider + "/")]
    if not slugs:
        print("no repos match the filter; nothing to do.")
        return 0

    now_ts = time.time()
    quiet = bool(args.quiet)

    summary = {"ok": 0, "skipped": 0, "failed": 0, "total_bytes": 0, "total_seconds": 0.0}
    if not quiet:
        print(f"sync target: {TARGET_ROOT}")
        print(f"candidates:  {len(slugs)} repo(s)  (defaults interval = {defaults.get('interval', '24h')})")
        if args.dry_run:
            print("(dry-run: no clones, no state writes)")
        print()

    longest = max(len(s) for s in slugs)
    for slug in slugs:
        config = load_repo_config(slug, defaults)
        interval_s = parse_interval(str(config.get("interval", "24h")))
        state = load_state(slug)
        due, why = is_due(state, interval_s, now_ts)

        if not (args.force or due):
            summary["skipped"] += 1
            if not quiet:
                print(f"  {slug:<{longest}}  skipped     ({why})")
            continue

        result = sync_one_repo(slug, config, dry_run=args.dry_run)

        if args.dry_run:
            if not quiet:
                print(f"  {slug:<{longest}}  {result['action']:<14} ({why})")
            continue

        # Update state and print summary line
        new_state = dict(state) if state else {"first_seen_at": iso_now()}
        new_state["last_attempt_at"] = iso_now()
        if result["ok"]:
            new_state["last_success_at"] = iso_now()
            new_state["last_duration_s"] = round(result["duration_s"], 1)
            new_state["last_size_bytes"] = result.get("size_bytes", 0)
            new_state["last_error"] = None
            new_state["upstream_present"] = True
            save_state(slug, new_state)
            summary["ok"] += 1
            summary["total_bytes"] += result.get("size_bytes", 0)
            summary["total_seconds"] += result["duration_s"]
            if not quiet:
                size_str = format_size(result.get("size_bytes", 0))
                dur_str = format_duration(result["duration_s"])
                print(f"  {slug:<{longest}}  {result['action']:<14}  {size_str:>9}  in {dur_str}")
        else:
            new_state["last_error"] = result["reason"]
            new_state["last_duration_s"] = round(result.get("duration_s", 0), 1)
            save_state(slug, new_state)
            summary["failed"] += 1
            # Failures always print, even in quiet mode (cron mails this).
            dur_str = format_duration(result.get("duration_s", 0))
            print(f"  {slug:<{longest}}  FAILED       {dur_str}  {result['reason'][:80]}",
                  file=sys.stderr)

    # In quiet mode, only emit the summary if something actually happened.
    # All-skipped (the normal cron case) stays silent so cron sends no mail.
    if not quiet:
        print()
        if args.dry_run:
            print(f"would process {len(slugs) - summary['skipped']} repo(s); "
                  f"{summary['skipped']} not due")
        else:
            print(f"summary: {summary['ok']} ok, {summary['failed']} failed, "
                  f"{summary['skipped']} skipped  |  "
                  f"{format_size(summary['total_bytes'])} on disk total, "
                  f"{format_duration(summary['total_seconds'])} cumulative")
    elif summary["ok"] or summary["failed"]:
        # Quiet mode + something happened → one-line summary (to stderr if any
        # failed, stdout otherwise) so cron can route per channel.
        stream = sys.stderr if summary["failed"] else sys.stdout
        print(
            f"tourbillon repos sync: {summary['ok']} ok, {summary['failed']} failed, "
            f"{summary['skipped']} skipped  |  "
            f"{format_size(summary['total_bytes'])} transferred",
            file=stream,
        )

    return 0 if summary["failed"] == 0 else 1


def cmd_not_yet(label: str):
    def _impl(args: argparse.Namespace) -> int:
        print(f"not yet implemented: {label}", file=sys.stderr)
        return 2
    return _impl


# ---------- CLI ----------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="tourbillon",
        description="Keeper of the home-backup system's state. See doc/NAMING.md.",
    )
    subs = p.add_subparsers(dest="command", required=True, metavar="<command>")

    # Top-level
    sp = subs.add_parser("status", help="one-screen rollup of saratoga + repos + pool + drive")
    sp.set_defaults(func=cmd_status)
    sp = subs.add_parser("health", help="disk + pool health (not yet implemented)")
    sp.set_defaults(func=cmd_not_yet("health"))
    sp = subs.add_parser("logs", help="recent job logs (not yet implemented)")
    sp.set_defaults(func=cmd_not_yet("logs"))

    # hosts noun
    hosts = subs.add_parser("hosts", help="linux host backups (rsync over SSH)")
    hsubs = hosts.add_subparsers(dest="hosts_cmd", required=True, metavar="<verb>")

    hp = hsubs.add_parser("ping", help="SSH-probe a host's reachability right now")
    hp.add_argument("host", help="configured host name (basename of configs/hosts/*.toml)")
    hp.set_defaults(func=cmd_hosts_ping)

    hp = hsubs.add_parser("status", help="per-host last-sync state + reachability summary")
    hp.add_argument("--name", help="show one specific host")
    hp.set_defaults(func=cmd_hosts_status)

    hp = hsubs.add_parser("issues", help="filtered status — only hosts not in 'ok' state")
    hp.add_argument("--quiet", action="store_true",
                    help="suppress 'no issues' line when everything is healthy (cron-friendly)")
    hp.set_defaults(func=cmd_hosts_issues)

    hp = hsubs.add_parser("sync", help="clone or rsync-update due, reachable hosts (n.y.i.)")
    hp.set_defaults(func=cmd_not_yet("hosts sync"))
    sp = subs.add_parser("perf", help="transfer-rate history (not yet implemented)")
    sp.set_defaults(func=cmd_not_yet("perf"))

    # repos noun
    repos = subs.add_parser("repos", help="git repo mirroring (github + bitbucket)")
    rsubs = repos.add_subparsers(dest="repos_cmd", required=True, metavar="<verb>")

    rp = rsubs.add_parser(
        "discover",
        help="enumerate upstream repos via API; create per-repo configs as needed",
    )
    rp.add_argument(
        "--no-commit", action="store_true",
        help="don't auto-commit newly-created config files (default: do commit)",
    )
    rp.set_defaults(func=cmd_repos_discover)

    rp = rsubs.add_parser("status", help="per-repo last-run state, age, size")
    rp.add_argument("--name", metavar="SLUG", help="show one specific repo")
    rp.add_argument("--provider", choices=("github", "bitbucket"),
                    help="restrict to one provider")
    rp.set_defaults(func=cmd_repos_status)

    rp = rsubs.add_parser("issues", help="filtered status — only repos not in 'ok' state")
    rp.add_argument("--provider", choices=("github", "bitbucket"),
                    help="restrict to one provider")
    rp.add_argument("--quiet", action="store_true",
                    help="suppress 'no issues' line when everything is healthy (cron-friendly)")
    rp.set_defaults(func=cmd_repos_issues)

    rp = rsubs.add_parser("sync", help="clone / remote-update due repos")
    rp.add_argument("--name", metavar="SLUG", help="sync only this repo (provider/owner/name)")
    rp.add_argument("--provider", choices=("github", "bitbucket"),
                    help="restrict to one provider")
    rp.add_argument("--force", action="store_true",
                    help="ignore interval; sync every matching repo")
    rp.add_argument("--dry-run", action="store_true",
                    help="show what would happen; touch no repos and no state")
    rp.add_argument("--quiet", action="store_true",
                    help="suppress per-repo success lines; print failures + summary only "
                         "(intended for cron — silent runs leave no mail)")
    rp.set_defaults(func=cmd_repos_sync)

    rp = rsubs.add_parser("prune", help="explicit removal of a local mirror (n.y.i.)")
    rp.add_argument("slug", help="provider/owner/repo to prune")
    rp.set_defaults(func=cmd_not_yet("repos prune"))

    return p


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        return args.func(args)
    except KeyboardInterrupt:
        print("interrupted", file=sys.stderr)
        return 130


if __name__ == "__main__":
    sys.exit(main())
