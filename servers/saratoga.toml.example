# Per-server config for `backup-server saratoga`.
# Drop a tuned version of this file at /kodiak00/etc/servers/saratoga.toml
# (no .example suffix) to make discovery deterministic.
#
# All fields are optional. If absent, the tool falls back to autofs maps,
# then to live probing the host with showmount / smbclient.

private_ip = "192.168.0.60"   # preferred 10 GbE interface
lan_ip     = "192.168.1.60"   # fallback (will WARN if used)
autofs_root = "/saratoga-01"  # where this host's shares are auto-mounted

# Optional: pin the mount list. Omit to take whatever autofs has configured.
# mounts = ["applications", "archives", "backups", "photography", "videos"]

# Optional: per-share rsync excludes (passed through verbatim).
# exclude = ["*.tmp", ".DS_Store"]
